# ==============================================
# Valdrics Production Environment Template
# ==============================================
#
# Prefer generating a fresh operator scaffold with:
#   uv run python scripts/generate_managed_runtime_env.py --environment production
#
# This checked-in template is placeholder-only and must not be deployed without
# replacing all REPLACE_WITH_* values.

# Core application
APP_NAME=Valdrics
DEBUG=false
TESTING=false
ENVIRONMENT=production
ENABLE_SCHEDULER=true
WEB_CONCURRENCY=2
APP_RUNTIME_DATA_DIR=/tmp/valdrics
CIRCUIT_BREAKER_DISTRIBUTED_STATE=true

# Public URLs
API_URL=https://REPLACE_WITH_API_DOMAIN
FRONTEND_URL=https://REPLACE_WITH_FRONTEND_DOMAIN
CORS_ORIGINS=["https://REPLACE_WITH_FRONTEND_DOMAIN"]

# Database and cache
DATABASE_URL=postgresql+asyncpg://REPLACE_WITH_DB_USER:REPLACE_WITH_DB_PASSWORD@REPLACE_WITH_DB_HOST:5432/postgres
DB_SSL_MODE=require
DB_USE_NULL_POOL=false
DB_EXTERNAL_POOLER=false
REDIS_URL=redis://REPLACE_WITH_REDIS_HOST:6379/0

# Supabase Auth
SUPABASE_URL=https://REPLACE_WITH_SUPABASE_PROJECT.supabase.co
SUPABASE_JWT_SECRET=REPLACE_WITH_SUPABASE_JWT_SECRET_MINIMUM_32_CHARS_VALUE

# Security and internal control-plane secrets
CSRF_SECRET_KEY=REPLACE_WITH_CSRF_SECRET_KEY
ENCRYPTION_KEY=REPLACE_WITH_ENCRYPTION_KEY
KDF_SALT=REPLACE_WITH_KDF_SALT
ADMIN_API_KEY=REPLACE_WITH_ADMIN_API_KEY
INTERNAL_JOB_SECRET=REPLACE_WITH_INTERNAL_JOB_SECRET
INTERNAL_METRICS_AUTH_TOKEN=REPLACE_WITH_INTERNAL_METRICS_AUTH_TOKEN
ENFORCEMENT_APPROVAL_TOKEN_SECRET=REPLACE_WITH_ENFORCEMENT_APPROVAL_TOKEN_SECRET
ENFORCEMENT_EXPORT_SIGNING_SECRET=REPLACE_WITH_ENFORCEMENT_EXPORT_SIGNING_SECRET

# Runtime safety and observability
SAAS_STRICT_INTEGRATIONS=true
EXPOSE_API_DOCUMENTATION_PUBLICLY=false
OTEL_LOGS_EXPORT_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=https://REPLACE_WITH_OTEL_COLLECTOR:4317
SENTRY_DSN=https://REPLACE_WITH_SENTRY_KEY@REPLACE_WITH_SENTRY_HOST/REPLACE_WITH_SENTRY_PROJECT
TRUST_PROXY_HEADERS=true
TRUSTED_PROXY_HOPS=1
TRUSTED_PROXY_CIDRS=["REPLACE_WITH_TRUSTED_PROXY_CIDR"]

# LLM provider
LLM_PROVIDER=groq
GROQ_API_KEY=REPLACE_WITH_GROQ_API_KEY
OPENAI_API_KEY=
CLAUDE_API_KEY=
GOOGLE_API_KEY=

# Paystack Billing
PAYSTACK_SECRET_KEY=sk_live_REPLACE_WITH_PAYSTACK_SECRET_KEY
PAYSTACK_PUBLIC_KEY=pk_live_REPLACE_WITH_PAYSTACK_PUBLIC_KEY
PAYSTACK_PLAN_STARTER=
PAYSTACK_PLAN_GROWTH=
PAYSTACK_PLAN_PRO=
PAYSTACK_PLAN_ENTERPRISE=

# Strict SaaS integrations keep these env-based routing secrets empty in production
SLACK_CHANNEL_ID=
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
GITHUB_ACTIONS_OWNER=
GITHUB_ACTIONS_REPO=
GITHUB_ACTIONS_WORKFLOW_ID=
GITHUB_ACTIONS_TOKEN=
GITHUB_ACTIONS_ENABLED=
GITLAB_CI_PROJECT_ID=
GITLAB_CI_TRIGGER_TOKEN=
GITLAB_CI_ENABLED=
GENERIC_CI_WEBHOOK_URL=
GENERIC_CI_WEBHOOK_BEARER_TOKEN=
GENERIC_CI_WEBHOOK_ENABLED=

# Optional but commonly used shared integrations
SLACK_BOT_TOKEN=

# Break-glass controls stay disabled unless an audited incident requires them
FORECASTER_ALLOW_HOLT_WINTERS_FALLBACK=false
FORECASTER_BREAK_GLASS_REASON=
FORECASTER_BREAK_GLASS_EXPIRES_AT=
ALLOW_INSECURE_OUTBOUND_TLS=false
OUTBOUND_TLS_BREAK_GLASS_REASON=
OUTBOUND_TLS_BREAK_GLASS_EXPIRES_AT=
